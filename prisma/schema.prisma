generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum Goal {
  LOSE
  MAINTAIN
  GAIN
}

enum ChronicDiseasesType {
  DISEASE
}

enum MealTime {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum ActivityLevelEnum {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum NotificationType {
  INFO
  MESSAGE
  REMINDER
  WARNING
  SUCCESS
  ERROR
}

enum QuestionStatus {
  PENDING
  ANSWERED
}

////////////////////////////
/// ADMIN
////////////////////////////

model Admin {
  id           String    @id @default(uuid())
  username     String    @unique
  name         String
  password     String
  isActive     Boolean   @default(true)
  tokenVersion Int       @default(0)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
}

////////////////////////////
/// USERS
////////////////////////////

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  email            String    @unique
  password         String
  isVerified       Boolean   @default(true)
  resetCode        String? // To store the 6-digit code
  resetCodeExpires DateTime? // To store the expiration time
  createdAt        DateTime  @default(now())

  /// Remaining complimentary plan generations (trial / gifts). Not tied to Plan row history.
  freePlansCount Int @default(1)

  /// Whether the user currently has a paid (or granted) subscription flag set.
  isSubscribed Boolean @default(false)

  /// Inclusive subscription period end; must be > now together with isSubscribed for active access.
  subscriptionEndDate DateTime?

  profile       Profile?
  plans         Plan[]
  progress      Progress[]
  notifications Notification[]
  questions     Question[]
}

//////////////////////////
/////////////////////////
//      Profile        //
/////////////////////////
model Profile {
  id              Int                      @id @default(autoincrement())
  userId          String                   @unique
  gender          Gender?
  age             Int?
  height          Float?
  currentWeight   Float?
  targetWeight    Float?
  goal            Goal?
  activityLevel   ActivityLevelEnum?
  chronicDiseases ProfileChronicDiseases[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

////////////////////////////
/// ChronicDiseases
////////////////////////////

model ChronicDiseases {
  id   Int                 @id @default(autoincrement())
  name String
  type ChronicDiseasesType

  meals    MealChronicDiseases[]
  profiles ProfileChronicDiseases[]
}

///////////////////////////
//   ProfileChronicDiseases
//////////////////////////
model ProfileChronicDiseases {
  id Int @id @default(autoincrement())

  profileId        Int
  chronicDiseaseId Int

  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chronicDisease ChronicDiseases @relation(fields: [chronicDiseaseId], references: [id], onDelete: Cascade)

  @@unique([profileId, chronicDiseaseId])
}

////////////////////////////
/// MEALS
////////////////////////////

model Meal {
  id          String   @id @default(uuid())
  name        String
  calories    Int
  portion     String?
  proteins    Float?
  fats        Float?
  carbs       Float?
  ingredients String[]
  imageUrl    String?
  time        MealTime
  createdAt   DateTime @default(now())

  chromicDiseases MealChronicDiseases[]
  planMeals       PlanMeal[]
}



////////////////////////////
/// MEAL ↔ ChronicDiseases (M-M)
////////////////////////////

model MealChronicDiseases {
  mealId            String
  chronicDiseasesId Int

  meal            Meal            @relation(fields: [mealId], references: [id], onDelete: Cascade)
  chronicDiseases ChronicDiseases @relation(fields: [chronicDiseasesId], references: [id], onDelete: Cascade)

  @@id([mealId, chronicDiseasesId])
}

////////////////////////////
/// PLANS
////////////////////////////

model Plan {
  id            String   @id @default(uuid())
  totalCalories Int
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meals PlanMeal[]
}

////////////////////////////
/// PLAN MEALS
////////////////////////////

model PlanMeal {
  id         String   @id @default(uuid())
  dayNumber  Int
  mealTime   MealTime
  multiplier Float    @default(1.0)

  planId String
  mealId String

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
}

////////////////////////////
/// PROGRESS TRACKING
////////////////////////////

model Progress {
  id             String   @id @default(uuid())
  newWeight      Float
  previousWeight Float
  date           DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

////////////////////////////
/// NOTIFICATIONS
////////////////////////////

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String?        // e.g., "نصائح الرياضة"
  question  String
  answer    String?
  status    QuestionStatus @default(PENDING)
  isRead    Boolean        @default(false)
  createdAt DateTime       @default(now())
}
